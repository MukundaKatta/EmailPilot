# EmailPilot Configuration
# Copy this file to .env and update values as needed

# Default tone for email drafts (formal, casual, friendly, urgent)
EMAILPILOT_DEFAULT_TONE=formal

# Default sender name
EMAILPILOT_SENDER_NAME=Your Name

# Default signature
EMAILPILOT_SIGNATURE=Best regards

# Enable debug logging
EMAILPILOT_DEBUG=false
